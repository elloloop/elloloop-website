---
import { ThemeScript, ThemeToggle } from '@refraction-ui/astro';
import '../styles/brand.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'elloloop — Building the future of learning.' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://elloloop.com" />
    <link rel="canonical" href="https://elloloop.com" />
    <ThemeScript />
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="header-inner">
        <a href="/" class="logo">ello<span>loop</span></a>
        
        <nav class="desktop-nav hidden md:flex">
          <ul class="nav-links">
            <li><a href="/#products">Products</a></li>
            <li><a href="/privacy-policy">Privacy</a></li>
          </ul>
        </nav>

        <div class="header-actions">
          <div class="hidden md:block">
            <ThemeToggle />
          </div>
          <button id="mobile-menu-btn" class="mobile-menu-btn md:hidden" aria-label="Menu">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          </button>
        </div>
      </div>
      
      <div id="mobile-menu" class="mobile-menu hidden">
        <nav>
          <ul class="mobile-nav-links">
            <li><a href="/#products">Products</a></li>
            <li><a href="/privacy-policy">Privacy</a></li>
          </ul>
        </nav>
        <div class="mobile-menu-footer">
          <ThemeToggle />
        </div>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-left">
          <p>© {new Date().getFullYear()} elloloop LTD. All rights reserved.</p>
        </div>
        <ul class="footer-links">
          <li><a href="/privacy-policy">Privacy Policy</a></li>
          <li><a href="mailto:info@elloloop.com">Contact</a></li>
        </ul>
      </div>
    </footer>

    <script is:inline>
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      if (mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });

        // Close on link click
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
          });
        });
      }
    </script>
  </body>
</html>
