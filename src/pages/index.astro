---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="elloloop — Building the future of learning and developer tools">
  <main>
    <section class="hero">
      <div class="hero-content">
        <h1>
          We build tools that<br />
          <span class="gradient-text">shape tomorrow</span>
        </h1>
        <p>
          From AI-powered interview prep to adaptive tutoring — we create products
          that make learning and building software feel effortless.
        </p>
        <a href="/#products" class="btn btn-primary">
          Explore our products →
        </a>
      </div>
    </section>

    <section class="section" id="products">
      <p class="section-title">Our Products</p>
      <h2>What we're building</h2>
      <p>Purpose-built tools for developers and learners, powered by AI.</p>

      <div class="products-grid">
        <div class="product-card">
          <div class="product-icon">🎯</div>
          <h3>EasyLoops</h3>
          <p>
            Practice coding with instant AI feedback. Mock interviews,
            collaborative live sessions, and structured courses to level
            up your engineering skills.
          </p>
          <a href="https://easyloops.app" class="product-link" target="_blank" rel="noopener">
            Visit easyloops.app →
          </a>
        </div>

        <div class="product-card">
          <div class="product-icon">🐢</div>
          <h3>Tortoise Learning</h3>
          <p>
            Adaptive maths tutoring with a 3D AI teacher. Personalised
            lessons, step-by-step guidance, and real-time progress tracking
            for students of all ages.
          </p>
          <a href="https://tortoiselearning.app" class="product-link" target="_blank" rel="noopener">
            Visit tortoiselearning.app →
          </a>
        </div>

        <div class="product-card">
          <div class="product-icon">🪁</div>
          <h3>TinyKite Tools</h3>
          <p>
            A growing suite of free, browser-based developer utilities — image processing,
            code formatters, and workflow automation, all running locally in your browser.
          </p>
          <a href="https://tinykite.co/tools" class="product-link" target="_blank" rel="noopener">
            Visit tinykite.co →
          </a>
        </div>
      </div>
    </section>

    <section class="section" id="about">
      <p class="section-title">About</p>
      <h2>Small team, big ambitions</h2>
      <p>
        elloloop is a London-based software company focused on education and developer
        experience. We believe the best tools are opinionated, beautiful, and built to
        get out of your way.
      </p>
    </section>

    <section class="cta-section">
      <h2>Ready to get started?</h2>
      <p>
        Jump into EasyLoops for coding practice, or explore Tortoise Learning
        for personalised maths tutoring.
      </p>
      <a href="https://easyloops.app" class="btn btn-primary" target="_blank" rel="noopener">
        Try EasyLoops free →
      </a>
    </section>
  </main>
</BaseLayout>
